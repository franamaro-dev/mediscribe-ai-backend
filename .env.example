# ============================================
# MediScribe AI - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# OpenAI API Key (required for real LLM processing)
# Leave empty to use mock/fallback mode
OPENAI_API_KEY=

# Database URL (SQLite default)
DATABASE_URL=sqlite+aiosqlite:///./mediscribe.db

# Debug mode (set to false in production)
DEBUG=true
